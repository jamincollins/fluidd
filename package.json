  "keywords": [
    "klipper"
  ],
  "license": "GPL-3.0",
  "readme": "README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fluidd-core/fluidd.git"
  },
  "overrides": {
    "@vue/tsconfig": {
      "vue": "$vue"
    },
    "glob": "^13.0.6",
    "monaco-editor": {
      "dompurify": "$dompurify"
    },
    "serialize-javascript": "^7.0.3",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "engines": {
    "node": "^22.12.0 || ^24"
  }
